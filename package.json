    "@vueuse/motion": "^3.0.3",
    "motion": "^12.38.0",
    "nuxt": "^4.4.2",
    "nuxt-site-config": "^4.0.8",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@nuxtjs/google-fonts": "^3.2.0",
    "concurrently": "^9.2.1"
