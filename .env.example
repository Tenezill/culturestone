# Base URL of the Strapi backend. Used by Nuxt at runtime (public) and by
# scripts/migrate-stones.mjs at development time.
STRAPI_URL=http://localhost:1337

# API token with write access to the `stones` content type. Only required for
# the migration script — do NOT ship this to the browser. Generate from
# Strapi admin: Settings > API Tokens > Create new API Token.
STRAPI_API_TOKEN=
